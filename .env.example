VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# Razorpay (use TEST key for development, LIVE key only in production servers)
VITE_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
